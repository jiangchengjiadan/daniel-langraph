
# LLM配置
# 模型名称
LLM_MODEL_ID="gpt-5-chat-latest"

# API密钥
LLM_API_KEY=

# 服务地址
LLM_BASE_URL=

# 超时时间（可选，默认60秒）
LLM_TIMEOUT=60

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# 日志级别
LOG_LEVEL=INFO

# Unsplash API Credentials 获取图片
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# 高德地图API配置
# MCP Server 使用 AMAP_MAPS_API_KEY；如果不配置，会回退到 AMAP_API_KEY
AMAP_MAPS_API_KEY=
AMAP_API_KEY=

# 高德 MCP 配置（教学默认使用官方 npm 包）
AMAP_MCP_COMMAND=npx
AMAP_MCP_PACKAGE=@amap/amap-maps-mcp-server
AMAP_MCP_TIMEOUT=30

# FlyAI/飞猪商品增强配置（默认关闭，开启后用于酒店图片/价格/预订链接和景点门票）
ENABLE_FLYAI=false
FLYAI_CLI=flyai
FLYAI_TIMEOUT=20
