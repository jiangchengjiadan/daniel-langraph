# PPTx RAG Configuration Template
# Copy this file to .env and modify the values

# API Configuration (OpenAI Compatible)
API_BASE_URL=https://api.openai.com/v1  # or your custom OpenAI-compatible endpoint
API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4  # or your custom model name
EMBEDDING_MODEL=text-embedding-3-large  # or your custom embedding model

# LangSmith (optional, disabled by default)
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pptx-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Data Directory
DATA_DIR=./data

# Image Server Port
IMAGE_SERVER_PORT=8080

# Retrieval Settings
RETRIEVAL_K=2                    # Number of results to retrieve
RETRIEVAL_K_MULTIPLIER=2         # Internal multiplier (for filtering)

# LLM Settings
LLM_TEMPERATURE=0.1              # LLM temperature (0.0-1.0, lower = more deterministic)
LLM_NUM_CTX=4096                 # Context window size
LLM_NUM_PREDICT=2048             # Max tokens to predict

# Retrieval Weights
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6
